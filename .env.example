# Django
DJANGO_SECRET_KEY=your-secret-key-min-50-chars
DJANGO_DEBUG=false
DJANGO_ALLOWED_HOSTS=localhost,127.0.0.1,.yourdomain.com

# Public base URL — used for canonical links and structured data (SEO); set to your real domain in production
SITE_URL=http://localhost:8000

# MongoDB Atlas (Docker deploy uses Atlas; no mongo container)
MONGODB_NAME=tzuratlink
MONGODB_HOST=cluster0.xxxxx.mongodb.net
MONGODB_USER=your_atlas_user
MONGODB_PASSWORD=your_atlas_password

# Redis – set when running on host; Docker compose sets REDIS_URL for the django container
# Optional: leave REDIS_URL unset for local testing to fall back to an in-memory cache (no Redis needed)
REDIS_URL=redis://localhost:6379/0

# Google OAuth (allauth social login) – optional for local testing; Google sign-in
# just won't work until these are set
# Google Cloud Console → APIs & Services → Credentials → OAuth 2.0 Client ID
GOOGLE_CLIENT_ID=your_client_id.apps.googleusercontent.com
GOOGLE_CLIENT_SECRET=your_client_secret

# Google Drive backup (service account) – optional for local testing; backups are
# silently skipped when GDRIVE_BACKUP_FOLDER_ID is unset. Used by core/backup.py
# and the backup_db management command.
# Google Cloud Console → IAM → Service Accounts → Keys → Add Key → JSON.
# GDRIVE_CREDENTIALS holds the full JSON key content (not a file path) — paste the
# downloaded key file's contents here as a single-line value.
GDRIVE_CREDENTIALS={"type":"service_account","project_id":"...","private_key":"...","client_email":"...", ...}
GDRIVE_BACKUP_FOLDER_ID=your_google_drive_folder_id

# Optional: static files output for collectstatic
# STATIC_ROOT=/var/www/tzuratlink/static

# Optional: force HTTPS redirect when behind a reverse proxy
# SECURE_SSL_REDIRECT=true
