# ── Django ────────────────────────────────────────────────────
DJANGO_SECRET_KEY=your-secret-key-min-50-chars
DJANGO_DEBUG=false
DJANGO_ALLOWED_HOSTS=localhost,127.0.0.1,.yourdomain.com

# ── MongoDB Atlas ─────────────────────────────────────────────
# (Docker deploy uses Atlas; no mongo container)
MONGODB_NAME=tzuratlink
MONGODB_HOST=cluster0.xxxxx.mongodb.net/?appName=TzuratLink
MONGODB_USER=your_atlas_user
MONGODB_PASSWORD=your_atlas_password

# ── Google OAuth (allauth social login) ───────────────────────
# Google Cloud Console → APIs & Services → Credentials → OAuth 2.0 Client ID
GOOGLE_CLIENT_ID=your_client_id.apps.googleusercontent.com
GOOGLE_CLIENT_SECRET=your_client_secret

# ── Google Drive backup (service account) ─────────────────────
# Google Cloud Console → IAM → Service Accounts → Keys → Add Key → JSON
# Store the full JSON content as GDRIVE_CREDENTIALS_JSON in GitHub Secrets.
# On the server the deploy workflow writes it to ./gdrive-key.json.
GDRIVE_CREDENTIALS=/run/secrets/gdrive-key.json
GDRIVE_BACKUP_FOLDER_ID=your_google_drive_folder_id

# ── Docker image (server only) ────────────────────────────────
# Set on the server so docker compose pulls the pre-built GHCR image.
# Leave unset locally to build from source with `docker compose build`.
DJANGO_IMAGE=ghcr.io/your-github-username/tzuratlink:latest

# ── HTTPS (production only) ───────────────────────────────────
SECURE_SSL_REDIRECT=true
