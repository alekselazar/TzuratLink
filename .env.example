# Django
DJANGO_SECRET_KEY=your-secret-key-min-50-chars
DJANGO_DEBUG=false
DJANGO_ALLOWED_HOSTS=localhost,127.0.0.1,.yourdomain.com

# MongoDB Atlas (Docker deploy uses Atlas; no mongo container)
MONGODB_NAME=tzuratlink
MONGODB_HOST=cluster0.xxxxx.mongodb.net
MONGODB_USER=your_atlas_user
MONGODB_PASSWORD=your_atlas_password

# Redis / SSR – set when running on host; Docker compose sets REDIS_URL and SSR_SERVICE_URL for the django container
REDIS_URL=redis://localhost:6379/0
SSR_SERVICE_URL=http://localhost:3000

# Google OAuth (allauth social login)
# Google Cloud Console → APIs & Services → Credentials → OAuth 2.0 Client ID
GOOGLE_CLIENT_ID=your_client_id.apps.googleusercontent.com
GOOGLE_CLIENT_SECRET=your_client_secret

# Google Drive backup (service account) – used by core/backup.py and the backup_db management command
# Google Cloud Console → IAM → Service Accounts → Keys → Add Key → JSON
GDRIVE_CREDENTIALS=/path/to/gdrive-key.json
GDRIVE_BACKUP_FOLDER_ID=your_google_drive_folder_id

# Optional: static files output for collectstatic
# STATIC_ROOT=/var/www/tzuratlink/static

# Optional: force HTTPS redirect when behind a reverse proxy
# SECURE_SSL_REDIRECT=true
